pipeline {
    agent any
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        stage('Build') {
            steps {
                bat 'if not exist classes mkdir classes'
                bat '''
                    dir /s /b eclipsetest\\src\\*.java > sources.txt
                    javac -encoding UTF-8 -d classes @sources.txt
                '''
            }
        }
        stage('Test') {
            steps {
                script {
                    def classpath = "classes;lib\\junit-platform-console-standalone-1.7.1.jar"
                    bat "java -cp ${classpath} org.junit.platform.console.ConsoleLauncher --scan-classpath > test_results.txt"
                }
            }
        }
    }
    post {
        always {
            archiveArtifacts artifacts: 'test_results.txt', allowEmptyArchive: true
        }
        failure {
            echo 'Build or test failed'
        }
        success {
            echo 'Build and test succeeded'
        }
    }
}
